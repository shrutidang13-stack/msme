{
  "loginRegister": {
    "css": ["a[href*='login']", "button[id*='login']", "button[class*='login']"],
    "xpath": [
      "//*[self::a or self::button or @role='button'][normalize-space(.)='Login/Register' or normalize-space(.)='Sign In/Sign Up' or contains(normalize-space(.),'Login/Register')]"
    ],
    "text": ["Login/Register", "Sign In/Sign Up"]
  },
  "loginOption": {
    "xpath": [
      "//*[self::a or self::button or @role='menuitem' or @role='button'][normalize-space(.)='Login' or normalize-space(.)='V3 Login']"
    ],
    "text": ["V3 Login", "Login"]
  },
  "userId": {
    "css": ["input[name='userId']", "input[name='username']", "input[id*='user']", "input[placeholder*='User']"],
